{
  "expo": {
    "name": "Yaqin Market",
    "slug": "yaqin-market",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#E53935"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "uz.yaqin.market",
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "Yaqin do'konlarni topish uchun joylashuvingiz kerak",
        "NSLocationAlwaysUsageDescription": "Yetkazib berish jarayonida joylashuvingizni kuzatish uchun"
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#E53935"
      },
      "package": "uz.yaqin.market",
      "permissions": [
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION",
        "FOREGROUND_SERVICE",
        "RECEIVE_BOOT_COMPLETED",
        "VIBRATE",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION"
      ],
      "edgeToEdgeEnabled": true
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "updates": {
      "enabled": false
    },
    "scheme": "yaqinmarket",
    "plugins": [
      "expo-router",
      "expo-secure-store",
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "Yaqin do'konlarni topish uchun joylashuvingiz kerak",
          "locationAlwaysAndWhenInUsePermission": "Yetkazib berish uchun joylashuv kerak"
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/icon.png",
          "color": "#E53935",
          "androidMode": "default"
        }
      ],
      "expo-font"
    ],
    "extra": {
      "router": {},
      "eas": {
        "projectId": "e92114b3-1380-4773-9645-1cf427e58d54"
      }
    },
    "owner": "tilav"
  }
}
