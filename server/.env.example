# system
PORT=5000
NODE_ENV=development
CLIENT_URL=http://localhost:5173
SERVER_URL=http://localhost:5000

# postgresql
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your_password
POSTGRES_DB=yaqin_market

# jwt
JWT_SECRET=your_jwt_secret_key
JWT_ALGORITHM=HS256

# redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=your_redis_password

# telegram
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
TELEGRAM_WEBHOOK_URL=https://your-domain.com/bot/webhook
TELEGRAM_WEBHOOK_SECRET=your_webhook_secret
TELEGRAM_WEBAPP_URL=https://your-domain.com

# Firebase (FCM push notifications — for mobile)
FIREBASE_PROJECT_ID=your_firebase_project_id
FIREBASE_CLIENT_EMAIL=your_firebase_client_email
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# click payments
CLICK_SERVICE_ID=
CLICK_MERCHANT_ID=
CLICK_SECRET_KEY=
CLICK_VALIDATE_SIGN_TIME=false
CLICK_RETURN_URL_BASE=http://localhost:5173

# DB sync (true only for development)
DB_SYNCHRONIZE=true
DB_LOGGING=false
